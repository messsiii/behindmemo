# ======================================
# 数据库配置
# ======================================
# 当前：共享国际版数据库
DATABASE_URL="your_postgres_database_url"
POSTGRES_URL="your_postgres_url"
POSTGRES_PRISMA_URL="your_postgres_prisma_url"
