# ======================================
# 认证配置
# ======================================
NEXTAUTH_URL=https://behindmemory.cn
NEXTAUTH_SECRET="your_nextauth_secret"

# 中国站隐藏Google OAuth，仅保留邮箱登录
# Google OAuth配置保留但不使用
GOOGLE_CLIENT_ID="not_used_in_china"
GOOGLE_CLIENT_SECRET="not_used_in_china"

# 邮件配置（使用国内邮件服务商）
EMAIL_FROM="noreply@behindmemory.cn"
EMAIL_SERVER_HOST="smtp.qq.com"
EMAIL_SERVER_PASSWORD="your_qq_email_password"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER="your_qq_email"

# ======================================
# AI服务配置
# ======================================
MINIMAX_API_KEY="your_minimax_api_key"
GEMINI_API_KEY="your_gemini_api_key"
REPLICATE_API_TOKEN="your_replicate_api_token"

# ======================================
# Redis缓存 (Upstash)
# ======================================
KV_REST_API_READ_ONLY_TOKEN="your_kv_readonly_token"
KV_REST_API_TOKEN="your_kv_api_token"
KV_REST_API_URL="your_kv_api_url"
KV_URL="your_kv_url"

# ======================================
# 支付配置
# ======================================
# Paddle国际支付 (中国站可能需要替换为支付宝/微信支付)
PADDLE_SANDBOX=false
PADDLE_API_KEY="your_paddle_api_key"
PADDLE_API_URL="https://api.paddle.com"
PADDLE_WEBHOOK_SECRET="your_paddle_webhook_secret"
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN="your_paddle_client_token"
NEXT_PUBLIC_PADDLE_CREDITS_1000_PRICE_ID="your_price_id"
NEXT_PUBLIC_PADDLE_CREDITS_100_PRICE_ID="your_price_id"
NEXT_PUBLIC_PADDLE_CREDITS_10_PRICE_ID="your_price_id"
NEXT_PUBLIC_PADDLE_CREDITS_500_PRICE_ID="your_price_id"
NEXT_PUBLIC_PADDLE_MONTHLY_PRICE_ID="your_price_id"

# ======================================
# 其他配置
# ======================================
NODE_ENV="production"
ADMIN_API_SECRET="your_admin_api_secret"

# ======================================
# 功能开关
# ======================================
# 禁用不适用于中国的功能
DISABLE_GOOGLE_SERVICES=true
DISABLE_VERCEL_ANALYTICS=true
ENABLE_CHINA_OPTIMIZATIONS=true